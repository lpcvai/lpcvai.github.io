---
import Layout from "../../../layouts/Layout.astro";
import CompTrack from "../../../components/CompTrack.astro";

export async function getStaticPaths() {
  return [
    { params: { track: "track1" } },
    { params: { track: "track2" } },
    { params: { track: "track3" } },
  ];
}

const { track } = Astro.params;

// Track titles
const trackTitles = {
  track1: "Image classification for different lighting conditions and styles",
  track2: "Open-vocabulary segmentation with text prompt",
  track3: "Monocular relative depth estimation",
};

// Track Google Doc URLs
const trackUrls = {
  track1: "2PACX-1vQ2PgERUC80J2Wxo4NAuTK48nzcX5r0DEraVvYzDiM_qygKjktmonCCt4C6VnoA5rd3RELyT7Me3bG7",
  track2: "2PACX-1vSrvuX2vIVrbMhoXQtHNjmyFfNKNPS54Euob_a9twSGjb9o_RQjwtpBept5aaWdas4aAhd-SPvX-QHT",
  track3: "2PACX-1vTWF7hlEQnL6yRqQqCF2__RuVL2KkxlVX2kWvuSIaDMAS1IVoRtpkgfx6yZLuuAOysQ48n6z1hQ0dqN",
};
---

<Layout>
  <main>
    <section id="facts">
      <div class="container">
        <header class="section-header text-center" id="data">
          <!-- Year-specific header -->
          <h3>2025 IEEE LOW-POWER COMPUTER VISION CHALLENGE</h3>

          <!-- Track dropdown -->
          <h4 class="p-0">
            <select
              onchange={`location.replace("/2025LPCVC/tracks/"+this.value);`}
            >
              <option value="track1" selected={track === "track1"}>Track 1</option>
              <option value="track2" selected={track === "track2"}>Track 2</option>
              <option value="track3" selected={track === "track3"}>Track 3</option>
            </select>
            &nbsp;<strong>{trackTitles[track]}</strong>
          </h4>
        </header>

        <!-- CompTrack handles only the iframe -->
        <CompTrack
          header={trackTitles[track]}
          url={trackUrls[track]}
        />

        <div class="pb-4"></div>
      </div>
    </section>
  </main>
</Layout>
